<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_momentrip_main"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingBottom="22dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_fragment_card"
            android:elevation="0dp"
            android:orientation="vertical"
            android:padding="@dimen/section_card_padding">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/home_title"
                android:textColor="@color/momentrip_ink"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="4dp"
                android:text="@string/home_description"
                android:textColor="@color/momentrip_muted"
                android:textSize="14sp" />

        </LinearLayout>

        <Button
            android:id="@+id/buttonHomeAdd"
            android:layout_width="@dimen/action_plus_size"
            android:layout_height="@dimen/action_plus_size"
            android:layout_marginTop="36dp"
            android:background="@drawable/bg_home_button"
            android:elevation="5dp"
            android:stateListAnimator="@animator/button_press"
            android:text="@string/action_plus"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="@string/home_add_guide"
            android:textColor="@color/momentrip_muted"
            android:textSize="14sp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>