<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_momentrip_main"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingBottom="22dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/section_card_height"
            android:background="@drawable/bg_fragment_card"
            android:elevation="1dp"
            android:orientation="vertical"
            android:padding="@dimen/section_card_padding">

            <TextView
                android:id="@+id/textCalendarTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/momentrip_ink"
                android:textSize="25sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textCalendarDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="3dp"
                android:text="@string/calendar_description"
                android:textColor="@color/momentrip_muted"
                android:textSize="14sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_fragment_card"
            android:elevation="1dp"
            android:orientation="vertical"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/buttonPrevMonth"
                    android:layout_width="48dp"
                    android:layout_height="match_parent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="‹"
                    android:textColor="@color/momentrip_ink"
                    android:textSize="34sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textCalendarMonth"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textColor="@color/momentrip_ink"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/buttonNextMonth"
                    android:layout_width="48dp"
                    android:layout_height="match_parent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="›"
                    android:textColor="@color/momentrip_ink"
                    android:textSize="34sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <GridLayout
                android:id="@+id/calendarGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:columnCount="7"
                android:orientation="horizontal" />

        </LinearLayout>

        <TextView
            android:id="@+id/textCalendarItems"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_empty_box"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:textColor="@color/momentrip_ink"
            android:textSize="14sp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>