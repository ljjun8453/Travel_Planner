<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_fragment_card"
    android:elevation="2dp"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/itemPlanPlace"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/momentrip_ink"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/itemPlanDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/momentrip_teal_dark"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/itemPlanMemo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/momentrip_muted"
        android:textSize="14sp" />

</LinearLayout>
