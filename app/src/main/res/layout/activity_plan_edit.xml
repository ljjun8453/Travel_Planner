<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_momentrip_main"
    android:fillViewport="true"
    android:importantForAutofill="no">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_content_panel"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/plan_edit_title_new"
            android:textColor="@color/momentrip_ink"
            android:textSize="28sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editPlanPlace"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="24dp"
            android:hint="@string/plan_hint_place"
            android:inputType="text"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true" />

        <EditText
            android:id="@+id/editPlanDate"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:clickable="true"
            android:focusable="false"
            android:hint="@string/plan_hint_date"
            android:inputType="none"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true" />

        <EditText
            android:id="@+id/editPlanMemo"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginTop="10dp"
            android:gravity="top"
            android:hint="@string/plan_hint_memo"
            android:inputType="textMultiLine"
            android:padding="14dp" />

        <ProgressBar
            android:id="@+id/progressPlanEdit"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:indeterminate="true"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonCancelPlan"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_tab_button_secondary"
                android:stateListAnimator="@null"
                android:text="@string/action_cancel"
                android:textAllCaps="false"
                android:textColor="@color/momentrip_ink"
                android:textStyle="bold" />

            <Button
                android:id="@+id/buttonSavePlan"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_save_button"
                android:stateListAnimator="@null"
                android:text="@string/action_save"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
