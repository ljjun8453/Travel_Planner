<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_momentrip_main"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_content_panel"
        android:elevation="2dp"
        android:orientation="vertical"
        android:padding="20dp">

        <ImageView
            android:id="@+id/detailImagePhoto"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:background="@drawable/bg_map_preview"
            android:contentDescription="@string/content_selected_photo"
            android:scaleType="centerCrop"
            android:src="@drawable/momentrip1" />

        <ProgressBar
            android:id="@+id/progressDetail"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:indeterminate="true"
            android:visibility="gone" />

        <TextView
            android:id="@+id/detailTextPlace"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:textColor="@color/momentrip_ink"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/detailTextVisitDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/momentrip_teal_dark"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/detailTextMemo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_empty_box"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:textColor="@color/momentrip_ink"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/detailTextLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_map_info"
            android:padding="16dp"
            android:textColor="@color/momentrip_muted"
            android:textSize="14sp" />

        <FrameLayout
            android:id="@+id/detailMapContainer"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_map_preview" />

        <TextView
            android:id="@+id/detailMapNotice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_map_info"
            android:padding="14dp"
            android:text="@string/detail_no_location"
            android:textColor="@color/momentrip_muted"
            android:textSize="13sp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonEditRecord"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/bg_save_button"
                android:stateListAnimator="@animator/button_press"
                android:text="@string/action_edit"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <Button
                android:id="@+id/buttonDeleteRecord"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_save_button"
                android:stateListAnimator="@animator/button_press"
                android:text="@string/action_delete"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>