<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_momentrip_main"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingTop="0dp"
    android:paddingBottom="22dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/planTopCard"
            android:layout_width="match_parent"
            android:layout_height="@dimen/section_card_height"
            android:background="@drawable/bg_fragment_card"
            android:elevation="0dp"
            android:orientation="vertical"
            android:padding="@dimen/section_card_padding">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_list_badge"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp"
                android:text="@string/nav_plans"
                android:textColor="@color/momentrip_teal_dark"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/plan_title"
                android:textColor="@color/momentrip_ink"
                android:textSize="25sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="3dp"
                android:text="@string/plan_description"
                android:textColor="@color/momentrip_muted"
                android:textSize="14sp" />

        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressTravelPlan"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="22dp"
            android:indeterminate="true"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/planEmptyBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_empty_box"
            android:elevation="0dp"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="@dimen/empty_box_padding_horizontal"
            android:paddingTop="@dimen/empty_box_padding_vertical"
            android:paddingEnd="@dimen/empty_box_padding_horizontal"
            android:paddingBottom="@dimen/empty_box_padding_vertical">

            <TextView
                android:id="@+id/buttonAddPlanIcon"
                android:layout_width="@dimen/action_plus_size"
                android:layout_height="@dimen/action_plus_size"
                android:background="@drawable/bg_home_button"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:stateListAnimator="@animator/button_press"
                android:text="@string/action_plus"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:text="@string/plan_empty_title"
                android:textColor="@color/momentrip_ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:lineSpacingExtra="3dp"
                android:text="@string/plan_empty_message"
                android:textColor="@color/momentrip_muted"
                android:textSize="13sp" />

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerTravelPlans"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never"
            android:visibility="gone" />

        <TextView
            android:id="@+id/buttonAddPlanBottom"
            android:layout_width="@dimen/action_plus_size"
            android:layout_height="@dimen/action_plus_size"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_home_button"
            android:clickable="true"
            android:elevation="6dp"
            android:focusable="true"
            android:gravity="center"
            android:stateListAnimator="@animator/button_press"
            android:text="@string/action_plus"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>