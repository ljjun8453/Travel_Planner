<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:padding="18dp">

    <LinearLayout
        android:id="@+id/planTopCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_fragment_card"
        android:elevation="3dp"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_list_badge"
            android:paddingStart="12dp"
            android:paddingTop="6dp"
            android:paddingEnd="12dp"
            android:paddingBottom="6dp"
            android:text="@string/nav_plans"
            android:textColor="@color/momentrip_teal_dark"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/plan_title"
            android:textColor="@color/momentrip_ink"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="3dp"
            android:text="@string/plan_description"
            android:textColor="@color/momentrip_muted"
            android:textSize="14sp" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerTravelPlans"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="18dp"
        android:clipToPadding="false"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/planTopCard" />

    <ProgressBar
        android:id="@+id/progressTravelPlan"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:indeterminate="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/recyclerTravelPlans"
        app:layout_constraintEnd_toEndOf="@id/recyclerTravelPlans"
        app:layout_constraintStart_toStartOf="@id/recyclerTravelPlans"
        app:layout_constraintTop_toTopOf="@id/recyclerTravelPlans" />

    <LinearLayout
        android:id="@+id/planEmptyBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_empty_box"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/planTopCard">

        <TextView
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:background="@drawable/bg_home_button"
            android:gravity="center"
            android:text="@string/action_plus"
            android:textColor="@color/momentrip_ink"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="@string/plan_empty_title"
            android:textColor="@color/momentrip_ink"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:text="@string/plan_empty_message"
            android:textColor="@color/momentrip_muted"
            android:textSize="13sp" />

        <Button
            android:id="@+id/buttonAddPlanFirst"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_save_button"
            android:minWidth="128dp"
            android:stateListAnimator="@null"
            android:text="@string/dialog_create_plan"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
