<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_momentrip_main"
    android:fillViewport="true"
    android:importantForAutofill="no">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_content_panel"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="20dp">

        <ImageView
            android:id="@+id/imagePhoto"
            android:layout_width="match_parent"
            android:layout_height="210dp"
            android:background="@drawable/bg_map_preview"
            android:contentDescription="@string/content_selected_photo"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_foreground" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonPickGallery"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_tab_button"
                android:stateListAnimator="@null"
                android:text="@string/action_pick_gallery"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <Button
                android:id="@+id/buttonTakePhoto"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_tab_button"
                android:stateListAnimator="@null"
                android:text="@string/action_take_photo"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold" />

        </LinearLayout>

        <EditText
            android:id="@+id/editPlace"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="18dp"
            android:hint="@string/hint_place"
            android:inputType="textCapWords"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true" />

        <EditText
            android:id="@+id/editVisitDate"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:hint="@string/hint_visit_date"
            android:inputType="date"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true" />

        <EditText
            android:id="@+id/editMemo"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="10dp"
            android:gravity="top"
            android:hint="@string/hint_memo"
            android:inputType="textMultiLine"
            android:padding="14dp" />

        <EditText
            android:id="@+id/editLatitude"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:hint="@string/hint_latitude"
            android:inputType="numberDecimal|numberSigned"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true" />

        <EditText
            android:id="@+id/editLongitude"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:hint="@string/hint_longitude"
            android:inputType="numberDecimal|numberSigned"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true" />

        <ProgressBar
            android:id="@+id/progressAddEdit"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:indeterminate="true"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonSave"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_tab_button"
                android:stateListAnimator="@null"
                android:text="@string/action_save"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <Button
                android:id="@+id/buttonCancel"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_tab_button_secondary"
                android:stateListAnimator="@null"
                android:text="@string/action_cancel"
                android:textAllCaps="false"
                android:textColor="@color/momentrip_ink"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
