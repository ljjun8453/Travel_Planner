<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:padding="18dp">

    <LinearLayout
        android:id="@+id/mapTopCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_fragment_card"
        android:elevation="3dp"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/textTravelMapBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_map_badge"
            android:paddingStart="12dp"
            android:paddingTop="6dp"
            android:paddingEnd="12dp"
            android:paddingBottom="6dp"
            android:text="@string/badge_location"
            android:textColor="@color/momentrip_orange_dark"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textTravelMapTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/map_title"
            android:textColor="@color/momentrip_ink"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textTravelMapDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="3dp"
            android:text="@string/map_description"
            android:textColor="@color/momentrip_muted"
            android:textSize="14sp" />

    </LinearLayout>

    <FrameLayout
        android:id="@+id/mapPreviewBox"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_map_preview"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_min="260dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/mapTopCard">

        <TextView
            android:id="@+id/textMapMarker"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_icon_circle_map"
            android:gravity="center"
            android:text="@string/map_marker_empty"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/mapEmptyInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_map_info"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/textTravelMapMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/map_empty_title"
                android:textColor="@color/momentrip_ink"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textTravelMapGuide"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="3dp"
                android:text="@string/map_empty_message"
                android:textColor="@color/momentrip_muted"
                android:textSize="13sp" />

        </LinearLayout>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
