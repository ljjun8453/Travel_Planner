<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_momentrip_main"
    android:clipChildren="false"
    android:clipToPadding="false">

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/screen_side_margin"
        android:layout_marginTop="@dimen/screen_top_margin"
        android:layout_marginEnd="@dimen/screen_side_margin"
        android:background="@drawable/bg_header_card"
        android:elevation="2dp"
        android:orientation="vertical"
        android:paddingStart="@dimen/header_horizontal_padding"
        android:paddingTop="@dimen/header_top_padding"
        android:paddingEnd="@dimen/header_horizontal_padding"
        android:paddingBottom="@dimen/header_bottom_padding"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textAppName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/app_name_lower"
                android:textColor="@color/momentrip_orange_dark"
                android:textSize="17sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/textMainTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/main_title"
            android:textColor="@color/momentrip_ink"
            android:textSize="29sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textMainSubTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="3dp"
            android:text="@string/main_subtitle"
            android:textColor="@color/momentrip_muted"
            android:textSize="14sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/buttonLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/screen_side_margin"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="@dimen/screen_side_margin"
        android:background="@drawable/bg_tab_shell"
        android:elevation="12dp"
        android:orientation="horizontal"
        android:padding="5dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <Button
            android:id="@+id/buttonTravelList"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_button"
            android:minHeight="0dp"
            android:stateListAnimator="@animator/button_press"
            android:text="@string/tab_list"
            android:textAllCaps="false"
            android:textColor="@color/tab_button_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/buttonTravelMap"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_button"
            android:minHeight="0dp"
            android:stateListAnimator="@animator/button_press"
            android:text="@string/tab_map"
            android:textAllCaps="false"
            android:textColor="@color/tab_button_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/buttonCalendarView"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_button"
            android:minHeight="0dp"
            android:stateListAnimator="@animator/button_press"
            android:text="@string/tab_calendar"
            android:textAllCaps="false"
            android:textColor="@color/tab_button_text"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/screen_side_margin"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="@dimen/screen_side_margin"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_momentrip_main"
        android:clipChildren="true"
        android:clipToPadding="true"
        android:elevation="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonLayout">

        <include
            layout="@layout/fragment_travel_list"
            android:visibility="gone"
            tools:visibility="visible" />

    </FrameLayout>

    <FrameLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="92dp"
        android:background="@android:color/transparent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/bottomBarLayout"
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_bottom_nav"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="@dimen/bottom_nav_padding_horizontal"
            android:paddingTop="12dp"
            android:paddingEnd="@dimen/bottom_nav_padding_horizontal"
            android:paddingBottom="10dp">

            <Button
                android:id="@+id/buttonNavRecords"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:stateListAnimator="@animator/button_press"
                android:text="@string/nav_records"
                android:textAllCaps="false"
                android:textColor="@color/momentrip_muted"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="100dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/buttonNavPlans"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:stateListAnimator="@animator/button_press"
                android:text="@string/nav_plans"
                android:textAllCaps="false"
                android:textColor="@color/momentrip_muted"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <Button
            android:id="@+id/buttonNavHome"
            android:layout_width="78dp"
            android:layout_height="78dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_home_button"
            android:elevation="10dp"
            android:stateListAnimator="@animator/button_press"
            android:text="@string/nav_home"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

    </FrameLayout>

    <ProgressBar
        android:id="@+id/progressMain"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:elevation="24dp"
        android:indeterminate="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/fragmentContainer"
        app:layout_constraintEnd_toEndOf="@id/fragmentContainer"
        app:layout_constraintStart_toStartOf="@id/fragmentContainer"
        app:layout_constraintTop_toTopOf="@id/fragmentContainer" />

</androidx.constraintlayout.widget.ConstraintLayout>